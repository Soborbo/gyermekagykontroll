---
interface Props {
  icon: string;
  title: string;
  text: string;
  color?: string;
}

const { icon, title, text, color = "blue" } = Astro.props;

const iconMap: Record<string, string> = {
  book: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253",
  shield: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
  moon: "M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z",
  cloud: "M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z",
  brain: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z",
  "x-circle": "M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z",
  target: "M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z",
  zap: "M13 10V3L4 14h7v7l9-11h-7z",
  flag: "M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9",
  heart: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
  "plus-circle": "M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z",
  sun: "M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z",
};

const colorStyles: Record<string, { bg: string; border: string; iconBg: string; iconText: string; titleText: string }> = {
  blue:    { bg: "bg-blue-50/50",    border: "border-blue-200",    iconBg: "bg-blue-100",    iconText: "text-blue-600",    titleText: "text-blue-800" },
  green:   { bg: "bg-green-50/50",   border: "border-green-200",   iconBg: "bg-green-100",   iconText: "text-green-600",   titleText: "text-green-800" },
  indigo:  { bg: "bg-indigo-50/50",  border: "border-indigo-200",  iconBg: "bg-indigo-100",  iconText: "text-indigo-600",  titleText: "text-indigo-800" },
  purple:  { bg: "bg-purple-50/50",  border: "border-purple-200",  iconBg: "bg-purple-100",  iconText: "text-purple-600",  titleText: "text-purple-800" },
  amber:   { bg: "bg-amber-50/50",   border: "border-amber-200",   iconBg: "bg-amber-100",   iconText: "text-amber-600",   titleText: "text-amber-800" },
  rose:    { bg: "bg-rose-50/50",    border: "border-rose-200",    iconBg: "bg-rose-100",    iconText: "text-rose-600",    titleText: "text-rose-800" },
  teal:    { bg: "bg-teal-50/50",    border: "border-teal-200",    iconBg: "bg-teal-100",    iconText: "text-teal-600",    titleText: "text-teal-800" },
  orange:  { bg: "bg-orange-50/50",  border: "border-orange-200",  iconBg: "bg-orange-100",  iconText: "text-orange-600",  titleText: "text-orange-800" },
  cyan:    { bg: "bg-cyan-50/50",    border: "border-cyan-200",    iconBg: "bg-cyan-100",    iconText: "text-cyan-600",    titleText: "text-cyan-800" },
  pink:    { bg: "bg-pink-50/50",    border: "border-pink-200",    iconBg: "bg-pink-100",    iconText: "text-pink-600",    titleText: "text-pink-800" },
  emerald: { bg: "bg-emerald-50/50", border: "border-emerald-200", iconBg: "bg-emerald-100", iconText: "text-emerald-600", titleText: "text-emerald-800" },
  yellow:  { bg: "bg-yellow-50/50",  border: "border-yellow-200",  iconBg: "bg-yellow-100",  iconText: "text-yellow-600",  titleText: "text-yellow-800" },
};

const c = colorStyles[color] || colorStyles.blue;
const path = iconMap[icon] || iconMap.sun;
---

<div class={`group rounded-2xl p-6 border-2 transition-all hover:-translate-y-1 hover:shadow-md ${c.bg} ${c.border}`}>
  <div class={`w-12 h-12 rounded-xl flex items-center justify-center mb-4 ${c.iconBg}`}>
    <svg class={`w-6 h-6 ${c.iconText}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d={path} />
    </svg>
  </div>
  <h3 class={`text-lg font-bold mb-2 ${c.titleText}`}>{title}</h3>
  <p class="text-text-secondary text-sm leading-relaxed">{text}</p>
</div>
