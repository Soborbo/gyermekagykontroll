---
import { navigation, siteConfig } from "../content/site";
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <a href="/" class="flex items-center gap-2 shrink-0">
        <span class="text-xl lg:text-2xl font-extrabold text-primary-700 font-heading">
          Gyermekagykontroll
        </span>
      </a>

      <nav class="hidden lg:flex items-center gap-1">
        {navigation.map((item) => (
          <a
            href={item.href}
            class="px-3 py-2 text-sm font-medium text-text-secondary hover:text-primary-700 rounded-lg hover:bg-primary-50 transition-colors"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <a
        href="/jelentkezes"
        class="hidden lg:inline-flex items-center px-5 py-2.5 bg-coral-500 hover:bg-coral-600 text-white font-semibold rounded-lg transition-colors text-sm"
      >
        Jelentkezem!
      </a>

      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-text-secondary hover:text-primary-700 rounded-lg"
        aria-label="Menü megnyitása"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden border-t border-border bg-white">
    <div class="px-4 py-4 space-y-1">
      {navigation.map((item) => (
        <a
          href={item.href}
          class="block px-4 py-3 text-base font-medium text-text-secondary hover:text-primary-700 hover:bg-primary-50 rounded-lg transition-colors"
        >
          {item.label}
        </a>
      ))}
      <a
        href="/jelentkezes"
        class="block px-4 py-3 mt-2 bg-coral-500 hover:bg-coral-600 text-white font-semibold rounded-lg text-center transition-colors"
      >
        Jelentkezem!
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
