---
interface Props {
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  ctaText?: string;
  ctaHref?: string;
  badge?: string;
}

const {
  title,
  subtitle,
  image,
  imageAlt = "",
  ctaText = "Jelentkezem!",
  ctaHref = "/jelentkezes",
  badge,
} = Astro.props;
---

<section class="relative overflow-hidden text-white">
  {/* Kép rész – teljes mértékben látható */}
  {image && (
    <div class="relative w-full h-[300px] sm:h-[400px] lg:h-[480px]">
      <img
        src={image}
        alt={imageAlt}
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
      />
      {/* Gradient átmenet: alulról sötétedik a kép */}
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-primary-800" />
    </div>
  )}

  {/* Szöveg rész – sötét háttéren */}
  <div class="bg-primary-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-16">
      <div class="max-w-3xl">
        {badge && (
          <span class="inline-block px-4 py-1.5 bg-amber-400/20 text-amber-300 text-sm font-semibold rounded-full mb-6 border border-amber-400/30">
            {badge}
          </span>
        )}
        <h1 class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-extrabold leading-tight mb-6">
          {title}
        </h1>
        {subtitle && (
          <p class="text-lg sm:text-xl text-primary-100 leading-relaxed mb-8 max-w-2xl">
            {subtitle}
          </p>
        )}
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={ctaHref}
            class="inline-flex items-center justify-center px-8 py-4 bg-coral-500 hover:bg-coral-600 text-white font-bold rounded-xl text-lg transition-all hover:scale-105 shadow-lg"
          >
            {ctaText}
          </a>
          <slot name="secondary-cta" />
        </div>
      </div>
    </div>
  </div>
</section>
