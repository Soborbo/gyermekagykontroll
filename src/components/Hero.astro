---
interface Props {
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  ctaText?: string;
  ctaHref?: string;
  badge?: string;
  overlay?: boolean;
}

const {
  title,
  subtitle,
  image,
  imageAlt = "",
  ctaText = "Jelentkezem!",
  ctaHref = "/jelentkezes",
  badge,
  overlay = true,
} = Astro.props;
---

<section class="relative overflow-hidden bg-primary-700 text-white">
  {image && (
    <img
      src={image}
      alt={imageAlt}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
  )}
  {overlay && <div class="absolute inset-0 bg-gradient-to-r from-primary-900/70 via-primary-900/40 to-transparent" />}
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
    <div class="max-w-3xl">
      {badge && (
        <span class="inline-block px-4 py-1.5 bg-amber-400/20 text-amber-300 text-sm font-semibold rounded-full mb-6 border border-amber-400/30">
          {badge}
        </span>
      )}
      <h1 class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-extrabold leading-tight mb-6">
        {title}
      </h1>
      {subtitle && (
        <p class="text-lg sm:text-xl text-primary-100 leading-relaxed mb-8 max-w-2xl">
          {subtitle}
        </p>
      )}
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={ctaHref}
          class="inline-flex items-center justify-center px-8 py-4 bg-coral-500 hover:bg-coral-600 text-white font-bold rounded-xl text-lg transition-all hover:scale-105 shadow-lg"
        >
          {ctaText}
        </a>
        <slot name="secondary-cta" />
      </div>
    </div>
  </div>
</section>
