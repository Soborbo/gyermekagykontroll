---
interface Props {
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  ctaText?: string;
  ctaHref?: string;
  badge?: string;
}

const {
  title,
  subtitle,
  image,
  imageAlt = "",
  ctaText = "Jelentkezem!",
  ctaHref = "/jelentkezes",
  badge,
} = Astro.props;
---

{/* Mobil: kép felül 100% + szöveg alul | Desktop: 50-50 egymás mellett */}
<section class="bg-primary-800 text-white">
  <div class="flex flex-col lg:flex-row lg:min-h-[600px]">
    {/* --- Szöveg: mobilon alul, desktopon 50% bal oldal --- */}
    <div class="order-2 lg:order-1 flex flex-col justify-center w-full lg:w-1/2 px-4 sm:px-6 lg:px-12 xl:px-16 py-8 lg:py-16">

      {badge && (
        <span class="inline-block self-start px-4 py-1.5 bg-amber-400/20 text-amber-300 text-sm font-semibold rounded-full mb-4 lg:mb-6 border border-amber-400/30">
          {badge}
        </span>
      )}
      <h1 class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-extrabold leading-tight mb-4 lg:mb-6">
        {title}
      </h1>
      {subtitle && (
        <p class="text-lg sm:text-xl text-primary-100 leading-relaxed mb-6 lg:mb-8">
          {subtitle}
        </p>
      )}
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={ctaHref}
          class="inline-flex items-center justify-center px-8 py-4 bg-coral-500 hover:bg-coral-600 text-white font-bold rounded-xl text-lg transition-all hover:scale-105 shadow-lg"
        >
          {ctaText}
        </a>
        <slot name="secondary-cta" />
      </div>
    </div>

    {/* --- Kép: mobilon felül, desktopon 50% jobb oldal --- */}
    {image && (
      <div class="order-1 lg:order-2 relative w-full h-[50svh] lg:h-auto lg:w-1/2">
        <img
          src={image}
          alt={imageAlt}
          class="absolute inset-0 w-full h-full object-cover"
          loading="eager"
        />
      </div>
    )}
  </div>
</section>
