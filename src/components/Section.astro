---
interface Props {
  id?: string;
  title?: string;
  subtitle?: string;
  alt?: boolean;
  class?: string;
}

const { id, title, subtitle, alt = false, class: className = "" } = Astro.props;
---

<section id={id} class:list={[alt ? "bg-surface-alt" : "bg-white", "py-16 lg:py-24", className]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {title && (
      <div class="text-center mb-12 lg:mb-16">
        <h2 class="text-3xl lg:text-4xl font-extrabold text-primary-800 mb-4">{title}</h2>
        {subtitle && (
          <p class="text-lg text-text-secondary max-w-2xl mx-auto">{subtitle}</p>
        )}
      </div>
    )}
    <slot />
  </div>
</section>
