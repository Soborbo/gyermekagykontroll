---
interface Props {
  quote: string;
  author: string;
  role?: string;
}

const { quote, author, role } = Astro.props;
---

<div class="bg-white rounded-2xl p-8 shadow-sm border border-border">
  <svg class="w-8 h-8 text-amber-400 mb-4" fill="currentColor" viewBox="0 0 24 24">
    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z" />
  </svg>
  <p class="text-text-secondary leading-relaxed mb-4 italic">"{quote}"</p>
  <div>
    <p class="font-bold text-primary-800">{author}</p>
    {role && <p class="text-sm text-text-secondary">{role}</p>}
  </div>
</div>
