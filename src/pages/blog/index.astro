    tag: "Önismeret",
    icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  },
];

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return d.toLocaleDateString("hu-HU", { year: "numeric", month: "long", day: "numeric" });
}

const tagColors: Record<string, string> = {
  "Tanulás": "bg-amber-100 text-amber-800",
  "Nevelés": "bg-red-100 text-red-800",
  "Gyermekagykontroll": "bg-primary-100 text-primary-800",
  "Személyes": "bg-emerald-100 text-emerald-800",
  "Tanfolyam": "bg-violet-100 text-violet-800",
  "Stresszoldás": "bg-orange-100 text-orange-800",
  "Önismeret": "bg-sky-100 text-sky-800",
};

const tagIconBg: Record<string, string> = {
  "Tanulás": "bg-amber-500",
  "Nevelés": "bg-red-500",
  "Gyermekagykontroll": "bg-primary-600",
  "Személyes": "bg-emerald-500",
  "Tanfolyam": "bg-violet-500",
  "Stresszoldás": "bg-orange-500",
  "Önismeret": "bg-sky-500",
};

const featured = posts[0];
const rest = posts.slice(1);
---

<Layout title="Blog" description="Gyermekagykontroll blog – cikkek a tanulásról, nevelésről és az agykontroll módszerről.">
  <section class="bg-primary-800 text-white py-16 lg:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-tight mb-4">
        Blog
      </h1>
      <p class="text-lg text-primary-200">
        Cikkek a tanulásról, nevelésről és az agykontroll módszerről
      </p>
    </div>
  </section>

  <Section>
    <div class="max-w-6xl mx-auto">
      <!-- Kiemelt poszt -->
      <a
        href={`/blog/${featured.slug}`}
        class="block bg-primary-800 rounded-2xl p-8 sm:p-10 mb-8 group hover:bg-primary-700 transition-colors"
      >
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class:list={["text-xs font-semibold px-2.5 py-1 rounded-full", tagColors[featured.tag]]}>
            {featured.tag}
          </span>
          <time class="text-sm text-primary-300">{formatDate(featured.date)}</time>
        </div>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-white mb-4 group-hover:text-amber-300 transition-colors">
          {featured.title}
        </h2>
        <p class="text-primary-200 text-lg leading-relaxed max-w-2xl">
          {featured.excerpt}
        </p>
        <span class="inline-flex items-center gap-1 mt-6 text-sm font-semibold text-amber-300 group-hover:text-amber-200">
          Tovább olvasom
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </span>
      </a>

      <!-- Csempék -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {rest.map((post) => (
          <a
            href={`/blog/${post.slug}`}
            class="group flex flex-col bg-white border border-border rounded-2xl overflow-hidden hover:shadow-xl hover:border-primary-200 hover:-translate-y-1 transition-all"
          >
            <div class="p-6 flex flex-col flex-1">
              <div class:list={["w-12 h-12 rounded-xl flex items-center justify-center mb-4", tagIconBg[post.tag] || "bg-gray-500"]}>
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={post.icon} />
                </svg>
              </div>
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class:list={["text-xs font-semibold px-2 py-0.5 rounded-full", tagColors[post.tag] || "bg-gray-100 text-gray-700"]}>
                  {post.tag}
                </span>
                <time class="text-xs text-text-secondary">{formatDate(post.date)}</time>
              </div>
              <h2 class="text-lg font-bold text-primary-800 group-hover:text-primary-600 transition-colors mb-2 leading-snug">
                {post.title}
              </h2>
              <p class="text-sm text-text-secondary leading-relaxed flex-1">
                {post.excerpt}
              </p>
              <span class="inline-flex items-center gap-1 mt-4 text-sm font-semibold text-primary-600 group-hover:text-primary-500">
                Tovább olvasom
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </Section>
</Layout>
