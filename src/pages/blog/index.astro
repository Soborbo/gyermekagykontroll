---
import Layout from "../../layouts/Layout.astro";
import Section from "../../components/Section.astro";

const posts = [
  {
    slug: "tanulasi-tippek-gyerekeknek",
    title: "Tanulási tippek gyerekeknek: Hogyan tanulj gyorsan és hatékonyan?",
