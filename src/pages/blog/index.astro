    tag: "Tanulás",
    icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253",
  },
  {
    slug: "gyermekagykontroll-stressz",
    title: "Öt működő stresszoldó gyakorlat gyerekeknek",
    date: "2024-01-15",
    excerpt: "Egyszerű technikák, amelyek bárhol kivitelezhetők és jótékony hatással vannak a lélekre és a testre egyaránt.",
    tag: "Stresszoldás",
    icon: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
  },
  {
    slug: "az-okostelefonok-5-karos-hatasa-a-gyerekekre",
    title: "Az okostelefonok 5 káros hatása a gyerekekre",
    date: "2023-12-14",
    excerpt: "Az okoskütyük hasznos informatikai segédeszközök, csakhogy itt már sokkal többről van szó. A gyerekeink, unokáink egészségéről!",
    tag: "Nevelés",
    icon: "M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z",
  },
  {
    slug: "gyermekagykontroll-tihanyi",
    title: "6 dolog, amiben segíteni tudok a gyerekednek",
    date: "2019-01-29",
    excerpt: "Tihanyi Rita pedagógus és gyermekagykontroll-oktató vagyok. Lássuk, mi az a hat terület, amiben segíteni tudok a gyermekednek!",
    tag: "Gyermekagykontroll",
    icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z",
  },
  {
    slug: "agykontroll-sikereim",
    title: "Személyes sikereim az agykontrollal",
    date: "2018-09-16",
    excerpt: "Hogyan adtam el a családi házunkat vizualizációval, és hogyan kukucskáltam haza Budapestről alfában? Személyes történeteim.",
