---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import BenefitCard from "../components/BenefitCard.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import { benefits } from "../content/courses";
import { courses } from "../content/courses";
import { siteConfig } from "../content/site";

const agykontroll = courses[0];
const tantorta = courses[1];
---

<Layout>
  <!-- HERO -->
  <Hero
    title="Adj esélyt a gyermekednek, hogy a legjobb verzióját élje!"
    subtitle="A gyermekagykontroll egy tudományosan megalapozott módszer, amellyel gyermeked megtanulja tudatosan használni a gondolatai erejét. 9-14 éveseknek, Budapesten és a Balaton környékén."
    image="/images/tanfolyam/nagy-kor.jpg"
    imageAlt="Gyermekagykontroll tanfolyam"
    badge="15+ év tapasztalat · Több mint 500 gyermek"
  >
    <a
      slot="secondary-cta"
      href="/tanulas"
      class="inline-flex items-center justify-center px-8 py-4 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-xl text-lg transition-all border border-white/20"
    >
      Mi az agykontroll?
    </a>
  </Hero>

  <!-- JOSÉ SILVA IDÉZET -->
  <section class="bg-primary-700 text-white py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <blockquote class="text-xl lg:text-2xl font-semibold italic leading-relaxed mb-4">
        „Az egyik legjobb dolog a világon, ami egy gyerekkel történhet: a gyermekagykontroll.
        Felnőttként azt tanuljuk meg, hogyan javítsuk ki a hibáinkat – gyerekként azt,
        <em class="text-amber-300">hogyan ne is kövessük el azokat!</em>"
      </blockquote>
      <cite class="text-primary-200 not-italic">— José Silva</cite>
    </div>
  </section>

  <!-- PROBLÉMAFELVETÉS -->
  <Section title="Ismerős valamelyik helyzet?">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {[
        { emoji: "😰", text: "A gyermeked nehezen koncentrál, szóródik a figyelme?" },
        { emoji: "😴", text: "Nehezen alszik el, rossz álmai vannak, fáradtan ébred?" },
        { emoji: "😣", text: "Stresszel a felelések, dolgozatok előtt, van lámpaláza?" },
        { emoji: "😔", text: "Kevés az önbizalma, negatívan gondolkodik, szorongó?" },
      ].map((item) => (
        <div class="bg-amber-50 rounded-2xl p-6 border border-amber-100 text-center">
          <span class="text-4xl mb-3 block">{item.emoji}</span>
          <p class="text-text font-medium">{item.text}</p>
        </div>
      ))}
    </div>
    <div class="text-center mt-10">
      <p class="text-xl text-primary-700 font-bold">A gyermekagykontroll mindezekre megoldást nyújt.</p>
    </div>
  </Section>

  <!-- MI AZ AGYKONTROLL - rövid -->
  <Section alt title="Mindannyian zseninek születünk" subtitle="Egy csodálatos szuperszámítógép birtokában – ez az agyunk.">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-6">
        <p class="text-lg leading-relaxed text-text-secondary">
          Az agykontroll egy olyan <strong class="text-text">vallásoktól és ideológiáktól független</strong>,
          tudományos és jól belátható alapokon nyugvó módszer, amelynek célja, hogy gondolataink erejét
          saját javunkra tudjuk fordítani – és ezzel megváltozzon az életünk.
        </p>
        <p class="text-lg leading-relaxed text-text-secondary">
          Képzelj el egy <strong class="text-text">citromot</strong>. Lásd magad előtt, ahogy hűvös, hideg héján
          egy csillámló vízcsepp csurran lefelé. Most képzeld el, ahogy kettévágod. Érzed a citrom savanyú,
          fanyar illatát? Képzeletben fogd meg, tartsd a nyitott szád fölé és nyomd össze, hogy a nyelvedre
          folyjon savanyú leve.
        </p>
        <p class="text-lg leading-relaxed text-primary-700 font-semibold">
          Ugye, hogy nyeltél egyet? Pedig a citrom nem valódi – ez a gondolataid ereje!
        </p>
        <a href="/tanulas" class="inline-flex items-center text-coral-500 hover:text-coral-600 font-semibold gap-2 group">
          Tudj meg többet az agykontrollról
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      <div class="relative">
        <img
          src="/images/tanfolyam/rita-tanitasban.jpg"
          alt="Tihanyi Rita tanfolyamot tart"
          class="rounded-2xl shadow-xl w-full object-cover aspect-[4/3]"
          loading="lazy"
        />
        <div class="absolute -bottom-6 -left-6 bg-amber-400 text-primary-900 px-6 py-3 rounded-xl font-bold shadow-lg">
          15+ év tapasztalat
        </div>
      </div>
    </div>
  </Section>

  <!-- 12 TERÜLET -->
  <Section
    id="elonyok"
    title="12 terület, amiben a gyermekagykontroll megváltoztathatja gyermeked életét"
  >
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {benefits.map((b) => (
        <BenefitCard icon={b.icon} title={b.title} text={b.text} />
      ))}
    </div>
    <div class="text-center mt-12">
      <p class="text-lg text-text-secondary mb-6">
        Ugye belátod, <strong class="text-text">mekkora előnnyel indul</strong> az életben az a gyermek,
        aki ezeknek a képességeknek a birtokában van?
      </p>
      <a
        href="/jelentkezes"
        class="inline-flex items-center justify-center px-8 py-4 bg-coral-500 hover:bg-coral-600 text-white font-bold rounded-xl text-lg transition-all hover:scale-105 shadow-lg"
      >
        Jelentkezem a tanfolyamra!
      </a>
    </div>
  </Section>

  <!-- TANFOLYAM INFÓ -->
  <Section alt>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Gyermekagykontroll -->
      <div class="bg-white rounded-2xl p-8 shadow-sm border border-border">
        <span class="inline-block px-3 py-1 bg-primary-50 text-primary-700 text-sm font-semibold rounded-full mb-4">Gyermekagykontroll</span>
        <h3 class="text-2xl font-extrabold text-primary-800 mb-4">{agykontroll.priceLabel}</h3>
        <ul class="space-y-3 mb-6">
          <li class="flex items-start gap-3 text-text-secondary">
            <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Korosztály: <strong class="text-text">{agykontroll.ageRange}</strong></span>
          </li>
          <li class="flex items-start gap-3 text-text-secondary">
            <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Időtartam: <strong class="text-text">{agykontroll.duration}</strong></span>
          </li>
          <li class="flex items-start gap-3 text-text-secondary">
            <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Testvérkedvezmény: <strong class="text-text">{agykontroll.siblingDiscountLabel}</strong></span>
          </li>
          <li class="flex items-start gap-3 text-text-secondary">
            <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Ismétlők díja: <strong class="text-text">{agykontroll.repeatPriceLabel}</strong></span>
          </li>
        </ul>
        <h4 class="font-bold text-primary-800 mb-3">Legközelebbi időpontok:</h4>
        <div class="space-y-2 mb-6">
          {agykontroll.dates.map((d) => (
            <div class="flex items-center gap-3 text-sm">
              <span class="font-semibold text-primary-700 w-36">{d.date}</span>
              <span class="text-text-secondary">{d.location}</span>
            </div>
          ))}
        </div>
        <a
          href="/jelentkezes?tanfolyam=gyermekagykontroll"
          class="block text-center px-6 py-3 bg-coral-500 hover:bg-coral-600 text-white font-bold rounded-xl transition-colors"
        >
          Jelentkezem!
        </a>
      </div>

      <!-- Tantorta -->
      <div class="bg-white rounded-2xl p-8 shadow-sm border border-border">
        <span class="inline-block px-3 py-1 bg-amber-50 text-amber-600 text-sm font-semibold rounded-full mb-4">Tantorta tréning</span>
        <h3 class="text-2xl font-extrabold text-primary-800 mb-4">{tantorta.priceLabel}</h3>
        <ul class="space-y-3 mb-6">
          <li class="flex items-start gap-3 text-text-secondary">
            <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Korosztály: <strong class="text-text">{tantorta.ageRange}</strong></span>
          </li>
          <li class="flex items-start gap-3 text-text-secondary">
            <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Időtartam: <strong class="text-text">{tantorta.duration}</strong></span>
          </li>
          <li class="flex items-start gap-3 text-text-secondary">
            <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Kedvezmény: <strong class="text-text">{tantorta.siblingDiscountLabel}</strong></span>
          </li>
          <li class="flex items-start gap-3 text-text-secondary">
            <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Tanulásmódszertan felsősöknek</span>
          </li>
        </ul>
        <h4 class="font-bold text-primary-800 mb-3">Legközelebbi időpont:</h4>
        <div class="space-y-2 mb-6">
          {tantorta.dates.map((d) => (
            <div class="flex items-center gap-3 text-sm">
              <span class="font-semibold text-primary-700 w-36">{d.date}</span>
              <span class="text-text-secondary">{d.location}</span>
            </div>
          ))}
        </div>
        <a
          href="/jelentkezes?tanfolyam=tantorta"
          class="block text-center px-6 py-3 bg-amber-400 hover:bg-amber-500 text-primary-900 font-bold rounded-xl transition-colors"
        >
          Jelentkezem!
        </a>
      </div>
    </div>
    <p class="text-center text-sm text-text-secondary mt-6">
      A jelentkezés nem kötelező érvényű – részletes tájékoztatót küldünk emailben, és visszajelzünk telefonon.
    </p>
  </Section>

  <!-- AZ OKTATÓRÓL -->
  <Section title="Az oktatóról" subtitle="Tihanyi Rita – több mint 15 éve a gyerekekért">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="relative order-2 lg:order-1">
        <img
          src="/images/rita/rita-konyvvel.jpg"
          alt="Tihanyi Rita"
          class="rounded-2xl shadow-xl w-full object-cover aspect-[4/3]"
          loading="lazy"
        />
      </div>
      <div class="order-1 lg:order-2 space-y-6">
        <p class="text-lg leading-relaxed text-text-secondary">
          Több mint harminc éves pedagógusi pályafutásom és <strong class="text-text">tizenhat éves hivatalos
          gyermekagykontroll-oktatói munkám</strong> során, ha valamit, azt biztosan megtanultam, hogy a gyerekeket
          kell és lehet is partnerként kezelni.
        </p>
        <p class="text-lg leading-relaxed text-text-secondary">
          Ha tiszteljük és tiszteletben tartjuk azt a szintet, ahol éppen járnak fejlődésükben és azon a nyelven,
          azon a szinten adunk nekik akár „felsőbb szintű" tudást is, ahol vannak, el fogják tudni sajátítani
          és be fogják tudni építeni az életükbe.
        </p>
        <a href="/rolam" class="inline-flex items-center text-coral-500 hover:text-coral-600 font-semibold gap-2 group">
          Tovább a teljes bemutatkozásra
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </Section>

  <!-- VÉLEMÉNYEK -->
  <Section alt title="Vélemények a tanfolyamról" subtitle="Nézd meg más szülők és gyerekek visszajelzéseit!">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
      <TestimonialCard
        quote="Borzasztóan hálás vagyok Ritának! Végre valaki tényleg tudott segíteni."
        author="Édesanya, Budapest"
      />
      <TestimonialCard
        quote="A fiam sokkal nyugodtabb lett, könnyebben alszik el és a jegyei is javultak. A tanfolyam után egy teljesen más gyereket kaptam vissza."
        author="Szülő, Balaton környéke"
      />
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <a href="https://www.youtube.com/embed/kIoHSE8ry80" target="_blank" rel="noopener" class="group relative rounded-2xl overflow-hidden shadow-md aspect-video">
        <img src="/images/tanfolyam/velemenyek1.jpg" alt="Vélemény videó" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
        <div class="absolute inset-0 bg-black/30 flex items-center justify-center group-hover:bg-black/40 transition-colors">
          <svg class="w-16 h-16 text-white/90" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
        </div>
      </a>
      <a href="https://www.youtube.com/watch?v=Zv3QnKRFz-c" target="_blank" rel="noopener" class="group relative rounded-2xl overflow-hidden shadow-md aspect-video">
        <img src="/images/tanfolyam/velemenyek3.jpg" alt="Vélemény videó" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
        <div class="absolute inset-0 bg-black/30 flex items-center justify-center group-hover:bg-black/40 transition-colors">
          <svg class="w-16 h-16 text-white/90" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
        </div>
      </a>
      <a href="https://www.youtube.com/embed/zp8muVsSsuI" target="_blank" rel="noopener" class="group relative rounded-2xl overflow-hidden shadow-md aspect-video">
        <img src="/images/tanfolyam/velemenyek2.jpg" alt="Vélemény videó" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
        <div class="absolute inset-0 bg-black/30 flex items-center justify-center group-hover:bg-black/40 transition-colors">
          <svg class="w-16 h-16 text-white/90" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
        </div>
      </a>
    </div>
  </Section>

  <!-- CTA -->
  <section class="bg-primary-700 text-white py-16 lg:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-extrabold mb-6">Érdekli a gyermekagykontroll?</h2>
      <p class="text-lg text-primary-100 mb-8 max-w-2xl mx-auto">
        Jelentkezzen, és részletes tájékoztatót küldünk emailben. A jelentkezés nem kötelező érvényű
        – nincs szükség fizetésre, visszajelzünk telefonon is.
      </p>
      <a
        href="/jelentkezes"
        class="inline-flex items-center justify-center px-10 py-4 bg-coral-500 hover:bg-coral-600 text-white font-bold rounded-xl text-lg transition-all hover:scale-105 shadow-lg"
      >
        Érdekel, jelentkezem!
      </a>
    </div>
  </section>

  <!-- KAPCSOLAT -->
  <Section title="Kérdése van? Írjon nekünk!">
    <div class="max-w-xl mx-auto text-center space-y-4">
      <p class="text-lg text-text-secondary">Bármilyen kérdésben forduljon hozzánk bizalommal:</p>
      <div class="flex flex-col sm:flex-row justify-center gap-6 text-lg">
        <a href="tel:+36306207373" class="flex items-center justify-center gap-2 text-primary-700 hover:text-coral-500 font-semibold transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          {siteConfig.contact.phone}
        </a>
        <a href="mailto:info@gyermekagykontroll.hu" class="flex items-center justify-center gap-2 text-primary-700 hover:text-coral-500 font-semibold transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          {siteConfig.contact.email}
        </a>
      </div>
    </div>
  </Section>
</Layout>
