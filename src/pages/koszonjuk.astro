---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import { siteConfig } from "../content/site";
---

<Layout title="Köszönjük a jelentkezést!">
  <Section>
    <div class="max-w-2xl mx-auto text-center">
      <svg class="w-20 h-20 text-green-500 mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h1 class="text-3xl lg:text-4xl font-extrabold text-primary-800 mb-6">Köszönjük a jelentkezést!</h1>
      <p class="text-lg text-text-secondary mb-4">
        Jelentkezését megkaptuk, szeretettel várjuk a tanfolyamon!
      </p>
      <p class="text-text-secondary mb-8">
        Hamarosan levélben elküldjük a kiválasztott tanfolyammal kapcsolatos információkat.
        Ha bármilyen kérdése volna, keressen minket bátran:
      </p>

      <div class="bg-surface-alt rounded-2xl p-8 mb-8">
        <div class="flex items-center gap-4 justify-center mb-4">
          <img src="/images/rita/profile.jpg" alt="Tihanyi Rita" class="w-16 h-16 rounded-full object-cover" />
          <div class="text-left">
            <p class="font-bold text-primary-800">Tihanyi Rita, agykontroll-oktató</p>
            <p class="text-text-secondary">{siteConfig.contact.phone}</p>
            <p class="text-text-secondary">{siteConfig.contact.email}</p>
          </div>
        </div>
      </div>

      <p class="text-text-secondary font-semibold mb-8">
        Köszönjük, hogy megtisztelt bizalmával, reméljük, hamarosan találkozunk!
      </p>

      <a href="/" class="inline-flex items-center justify-center px-8 py-3 bg-primary-700 hover:bg-primary-800 text-white font-bold rounded-xl transition-colors">
        Vissza a főoldalra
      </a>
    </div>
  </Section>
</Layout>
