---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import { siteConfig } from "../content/site";
---

<Layout title="Relaxációs meeting" description="Belső csend címmel relaxációs meeting felnőtteknek és gyerekeknek. 120 perces foglalkozás.">
  <Hero
    title="Relaxációs meeting"
    subtitle="Belső csend címmel relaxációs meetingre invitálok minden felnőttet és gyereket, akik szeretnének ellazulni, illetve megtanulni a relaxálás technikáit."
    image="/images/tanfolyam/rita-interaktiv.jpg"
    imageAlt="Relaxációs meeting"
  />

  <Section>
    <div class="max-w-3xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        <div class="bg-surface-alt rounded-2xl p-8 text-center">
          <span class="text-4xl font-extrabold text-amber-400 block mb-2">120</span>
          <span class="text-text-secondary">perces foglalkozás</span>
        </div>
        <div class="bg-surface-alt rounded-2xl p-8 text-center">
          <span class="text-2xl font-extrabold text-primary-700 block mb-2">Kiscsoportos</span>
          <span class="text-text-secondary">személyre szabott figyelemmel</span>
        </div>
      </div>

      <div class="space-y-6 text-lg leading-relaxed text-text-secondary">
        <p>
          A foglalkozáson nem csak a hosszabb befelé figyelés rejtelmeibe vezetem be a résztvevőket, hanem a
          <strong class="text-text">röviden, szükségszerűen akár iskolában, munkahelyen is könnyedén kivitelezhető technikákat</strong>
          is tanítom nekik.
        </p>
      </div>

      <div class="mt-10 bg-white rounded-2xl p-8 shadow-sm border border-border">
        <h3 class="text-xl font-bold text-primary-800 mb-4">Részvételi díj</h3>
        <div class="space-y-3 mb-6">
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-text-secondary">Felnőtteknek</span>
            <span class="font-bold text-primary-700">2 500 Ft</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-text-secondary">Gyerekeknek (10 év alatt)</span>
            <span class="font-bold text-primary-700">2 000 Ft</span>
          </div>
        </div>
        <h3 class="text-xl font-bold text-primary-800 mb-4">Jelentkezés</h3>
        <p class="text-text-secondary mb-4">Telefonon vagy emailben:</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="tel:+36306207373" class="inline-flex items-center justify-center px-6 py-3 bg-coral-500 hover:bg-coral-600 text-white font-bold rounded-xl transition-colors">
            {siteConfig.contact.phone}
          </a>
          <a href="mailto:info@gyermekagykontroll.hu" class="inline-flex items-center justify-center px-6 py-3 bg-primary-700 hover:bg-primary-800 text-white font-bold rounded-xl transition-colors">
            {siteConfig.contact.email}
          </a>
        </div>
      </div>
    </div>
  </Section>
</Layout>
